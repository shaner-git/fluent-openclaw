{
  "name": "fluent-openclaw",
  "version": "0.1.6",
  "private": false,
  "type": "module",
  "description": "Native OpenClaw plugin packaging for Fluent skills, managed auth, and MCP setup.",
  "author": {
    "name": "Fluent",
    "email": "hello@meetfluent.app",
    "url": "https://mcp.meetfluent.app"
  },
  "homepage": "https://github.com/shaner-git/fluent-docs/blob/main/guides/connecting-to-openclaw.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaner-git/fluent-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/shaner-git/fluent-openclaw/issues",
    "email": "support@meetfluent.app"
  },
  "license": "MIT",
  "keywords": [
    "fluent",
    "meals",
    "health",
    "style",
    "openclaw",
    "plugin",
    "personal-mcp"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm pack --dry-run",
    "test": "node --test"
  },
  "files": [
    "assets",
    "docs",
    "skills",
    "src",
    ".mcp.hosted.json",
    ".mcp.json",
    ".mcp.local.json",
    ".mcp.oss.json",
    "CHANGELOG.md",
    "index.js",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "x-fluent": {
    "artifactKind": "standalone-openclaw-package",
    "canonicalPackageName": "fluent-openclaw",
    "packagingDecision": "oss-embedded-openclaw-bundle-is-a-distinct-helper-package",
    "ossEmbeddedPackageName": "fluent-openclaw-oss-helper",
    "ossEmbeddedPackageLocation": "fluent-oss/openclaw-plugin/fluent",
    "ossEmbeddedGenerationSource": "fluent-mcp/openclaw-plugin/fluent exported into fluent-oss",
    "ossEmbeddedVersionPolicy": "Tracks Fluent OSS bundled-helper revisions and is not the published fluent-openclaw package line.",
    "releaseChannel": "public-beta",
    "backendModesStatus": "plugin-managed-auth-beta",
    "backendModes": ["hosted", "local"],
    "legacyBackendModes": ["hosted", "local"],
    "deploymentTracks": ["cloud", "oss"],
    "defaultDeploymentTrack": "cloud",
    "minimumContractVersion": "2026-04-20.fluent-core-v1.37",
    "requiredHostedScopes": ["meals:read", "meals:write", "health:read", "health:write", "style:read", "style:write", "offline_access"],
    "pluginManagedAuth": true,
    "contacts": {
      "general": "hello@meetfluent.app",
      "support": "support@meetfluent.app",
      "security": "security@meetfluent.app"
    }
  }
}
